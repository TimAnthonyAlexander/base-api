# ===========================
# 🔧 Application Configuration
# ===========================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:7879
APP_HOST=127.0.0.1
APP_PORT=7879
APP_TRUST_PROXY=false

# ===========================
# 🌐 CORS Configuration
# ===========================
CORS_ALLOWLIST=http://127.0.0.1:5173,http://localhost:5173

# ===========================
# 🛠 Request & Upload Limits
# ===========================
REQUEST_MAX_JSON_MB=2
UPLOAD_MAX_MB=25
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,application/pdf

# ===========================
# 🔑 Session Configuration
# ===========================
SESSION_NAME=BASEAPISESSID
SESSION_SAMESITE=Lax
SESSION_SECURE=false

# ===========================
# 🗄 Database Configuration
# ===========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=baseapi
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_PERSISTENT=false

# ===========================
# 🌍 Internationalization (i18n)
# ===========================
I18N_DEFAULT_LOCALE=en
I18N_LOCALES=en,de,fr
I18N_PROVIDER=

# ===========================
# 🤖 API Keys
# ===========================
DEEPL_API_KEY=
OPENAI_API_KEY=

# ===========================
# 📊 Rate Limiting
# ===========================
RATE_LIMIT_DIR=storage/ratelimits
